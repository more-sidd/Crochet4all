# OPTIONAL — only needed to make the Blog a real shared community.
# Without these, the Blog still works but saves posts in each visitor's browser.
#
# 1. Make a free project at https://supabase.com
# 2. Project Settings -> API -> copy the URL and the "anon public" key
# 3. Copy this file to ".env" and paste them in below
# 4. Run the SQL in the README to create the tables
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

